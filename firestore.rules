rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Admin allowlist — keep in sync with dsa-platform/lib/admin.ts
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in [
          'syedfarooq1095@gmail.com'
        ];
    }

    match /users/{uid} {
      // Any signed-in user can READ user docs.
      // Needed for: leaderboard (top 100), public profiles, admin dashboard.
      // Only non-sensitive progress fields are surfaced in the UI.
      allow read: if request.auth != null;

      // A user may only WRITE their own document. Admins may write any (moderation).
      allow create, update, delete: if request.auth != null
        && (request.auth.uid == uid || isAdmin());
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
