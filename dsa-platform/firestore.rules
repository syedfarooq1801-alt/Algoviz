rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Admin allowlist — keep in sync with admin-dashboard/lib/admin.ts
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in [
          'syedfarooq1095@gmail.com'
        ];
    }

    // Unique username reservations. Doc id = lowercased handle, value = { uid }.
    // Existence of a doc means the handle is taken.
    match /usernames/{handle} {
      // Anyone signed in can check availability / resolve handle -> uid.
      allow read: if request.auth != null;
      // Claim a free handle (create) — reservation must point to the claimer.
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      // Idempotent re-claim of own handle — only the current owner.
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      // Release own handle (when switching to a new one).
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // Private user docs — hold email + full progress. Readable ONLY by the owner
    // or an admin. Other users can never query emails here.
    match /users/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || isAdmin());
      allow create, update, delete: if request.auth != null
        && (request.auth.uid == uid || isAdmin());
    }

    // Public projection — safe subset for leaderboard + public profiles.
    // Contains ONLY: username, photoURL, xp, streak, solvedCount, activeDays,
    // selectedTrack, createdAt. NO email, no raw progress maps.
    match /leaderboard/{uid} {
      allow read: if request.auth != null;            // any signed-in user
      allow write: if request.auth != null
        && request.auth.uid == uid;                   // owner maintains own projection
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
