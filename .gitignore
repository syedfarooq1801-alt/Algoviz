# Monorepo root — per-project .gitignore files live in dsa-platform/ and codealgo-app/

# Dependencies
node_modules/
**/node_modules/

# Env / secrets (defense-in-depth; sub-projects also ignore these)
.env
**/.env
.env*.local
**/.env*.local

# Editor / agent / session data
.claude/
.agents/
.vscode/
.idea/

# Build artifacts
**/.next/
**/dist/
**/.expo/
*.tsbuildinfo

# Root-level scratch / handoff junk (root-anchored — keep any committed inside sub-projects)
/*.zip
/*.dc.html
